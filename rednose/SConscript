import eigen

Import('env', 'common')

env = env.Clone()
env.Append(CPPPATH=[eigen.INCLUDE_DIR])

cc_sources = [
  "helpers/ekf_load.cc",
  "helpers/ekf_sym.cc",
]
libs = ["dl"]
if common != "":
  # for SWAGLOG support
  libs += [common, 'zmq']

ekf_objects = env.SharedObject(cc_sources)
rednose = env.Library("helpers/ekf_sym", ekf_objects, LIBS=libs)
rednose_python = env.SharedLibrary("helpers/ekf_sym_ctypes", ["helpers/ekf_sym_ctypes.cc", ekf_objects], LIBS=libs)

Export('rednose', 'rednose_python')
